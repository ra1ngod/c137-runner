# --- answer stage (run.mjs) ---
# Any OpenAI-compatible endpoint works. Default reproduces the published Pro run
# via Google's OpenAI-compat endpoint (same endpoint c137 prod uses).
BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
API_KEY=your-gemini-api-key
MODEL=gemini-3.1-pro-preview

# Published-run params — leave as-is to reproduce. reasoning_effort defaults to
# "medium" for Gemini models (native thinking, as the runs; 3.1 Pro cannot run
# with thinking off) and is omitted for others (gpt-4o rejects it).
# For the GPT-4o config use MAX_TOKENS=4000.
TEMPERATURE=0
MAX_TOKENS=24000
#REASONING_EFFORT=medium
CONC=6
OUT=out

# --- grading (official LongMemEval evaluator, separate key) ---
# The official judge is OpenAI gpt-4o, so grading needs an OpenAI key even if
# you ran the answers on Gemini.
OPENAI_API_KEY=your-openai-api-key
